{
  "rules": {
    "projects": {
      "$projectId": {
        "publicSettings": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "entries": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".indexOn": ["entryNumber", "emailHash"]
        },
        "protected": {
          "$secretHash": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },
    "feedback": {
      ".read": false,
      ".write": "auth != null"
    },
    ".read": false,
    ".write": false
  }
}
